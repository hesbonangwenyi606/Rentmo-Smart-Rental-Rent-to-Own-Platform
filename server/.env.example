# ───────────────────────────────────────────────
# Rentmo Server — Environment Variables
# Copy this file to .env and fill in your values
# ───────────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=development

# Database (SQLite for local dev)
DATABASE_URL="file:./dev.db"

# JWT Secrets — change these to long random strings in production
JWT_SECRET=rentmo_super_secret_jwt_key_change_me_in_production
JWT_REFRESH_SECRET=rentmo_refresh_secret_change_me_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# ─── M-Pesa Daraja API (Safaricom) ───────────
# Get credentials from developer.safaricom.co.ke
MPESA_CONSUMER_KEY=your_consumer_key_here
MPESA_CONSUMER_SECRET=your_consumer_secret_here
MPESA_SHORTCODE=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
MPESA_CALLBACK_URL=https://your-domain.com/api/payments/mpesa/callback
# Use sandbox for dev, production for live
MPESA_ENV=sandbox

# ─── Africa's Talking SMS ─────────────────────
AT_API_KEY=your_africas_talking_api_key
AT_USERNAME=sandbox
AT_SENDER_ID=RENTMO

# ─── Email (Nodemailer / SMTP) ────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@rentmo.online
