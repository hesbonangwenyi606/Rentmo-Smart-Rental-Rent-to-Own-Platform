generator client {
  provider = "prisma-client-js"
}

// Switch provider to "postgresql" and update DATABASE_URL for production
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  phone     String?
  // TENANT | LANDLORD | ADMIN
  role      String   @default("TENANT")
  // PENDING | VERIFIED | REJECTED
  kycStatus String   @default("PENDING")
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownedProperties       Property[]
  leases                Lease[]
  payments              Payment[]
  loanApplications      LoanApplication[]
  insuranceSubscription InsuranceSubscription?
  insuranceClaims       InsuranceClaim[]
  creditScore           CreditScore?
  notifications         Notification[]
  refreshTokens         RefreshToken[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// ─── Properties ──────────────────────────────────────────────────────────────

model Property {
  id            String   @id @default(cuid())
  title         String
  description   String?
  location      String
  neighborhood  String
  price         Int
  // RENT | RENT_TO_OWN
  type          String
  bedrooms      Int
  bathrooms     Int
  size          Int
  // JSON array of image URLs stored as string
  images        String   @default("[]")
  // JSON array of feature strings
  features      String   @default("[]")
  available     Boolean  @default(true)
  rating        Float    @default(0)
  reviews       Int      @default(0)
  propertyValue Int?
  equityRate    Float?
  ownerId       String
  owner         User     @relation(fields: [ownerId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  leases Lease[]
}

// ─── Leases ───────────────────────────────────────────────────────────────────

model Lease {
  id          String   @id @default(cuid())
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id])
  tenantId    String
  tenant      User     @relation(fields: [tenantId], references: [id])
  startDate   DateTime
  endDate     DateTime
  monthlyRent Int
  // ACTIVE | EXPIRED | TERMINATED
  status      String   @default("ACTIVE")
  equityBuilt Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  payments Payment[]
}

// ─── Payments ────────────────────────────────────────────────────────────────

model Payment {
  id             String   @id @default(cuid())
  leaseId        String?
  lease          Lease?   @relation(fields: [leaseId], references: [id])
  tenantId       String
  tenant         User     @relation(fields: [tenantId], references: [id])
  amount         Int
  // MPESA | CARD | BANK | LOAN
  method         String
  // PENDING | COMPLETED | FAILED | REFUNDED
  status         String   @default("PENDING")
  transactionRef String?  @unique
  mpesaReceiptNo String?
  checkoutId     String?
  description    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ─── Loans ───────────────────────────────────────────────────────────────────

model LoanApplication {
  id               String    @id @default(cuid())
  tenantId         String
  tenant           User      @relation(fields: [tenantId], references: [id])
  amount           Int
  purpose          String
  // PENDING | APPROVED | DISBURSED | REJECTED | REPAID
  status           String    @default("PENDING")
  monthlyRepayment Int?
  interestRate     Float     @default(8.5)
  disbursedAt      DateTime?
  repaidAt         DateTime?
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

// ─── Insurance ───────────────────────────────────────────────────────────────

model InsurancePlan {
  id          String @id @default(cuid())
  name        String
  price       Int
  description String
  // JSON array of feature objects {label, included}
  features    String @default("[]")

  subscriptions InsuranceSubscription[]
}

model InsuranceSubscription {
  id        String        @id @default(cuid())
  userId    String        @unique
  user      User          @relation(fields: [userId], references: [id])
  planId    String
  plan      InsurancePlan @relation(fields: [planId], references: [id])
  // active | cancelled | expired
  status    String        @default("active")
  renewsAt  DateTime
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  claims InsuranceClaim[]
}

model InsuranceClaim {
  id             String                @id @default(cuid())
  subscriptionId String
  subscription   InsuranceSubscription @relation(fields: [subscriptionId], references: [id])
  userId         String
  user           User                  @relation(fields: [userId], references: [id])
  reason         String
  amount         Int
  description    String
  // PENDING | APPROVED | REJECTED
  status         String                @default("PENDING")
  reference      String                @unique
  filedAt        DateTime              @default(now())
  resolvedAt     DateTime?
}

// ─── Credit Score ────────────────────────────────────────────────────────────

model CreditScore {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  score     Int      @default(500)
  // JSON array: [{month: "Jan", year: 2026, score: 720}]
  history   String   @default("[]")
  updatedAt DateTime @updatedAt
}

// ─── Notifications ───────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  // info | warning | success | error
  type      String   @default("info")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}
