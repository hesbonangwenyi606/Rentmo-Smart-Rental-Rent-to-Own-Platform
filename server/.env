# Rentmo Server — Local Development Environment

PORT=3001
NODE_ENV=development

DATABASE_URL="file:./dev.db"

JWT_SECRET=rentmo_dev_jwt_secret_32chars_min
JWT_REFRESH_SECRET=rentmo_dev_refresh_secret_32chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

FRONTEND_URL=http://localhost:5173

# ─── M-Pesa Daraja API ────────────────────────────────────────────────────────
# Get credentials from: https://developer.safaricom.co.ke
# For local dev, expose callback with ngrok:
#   npx ngrok http 3001
#   Then set MPESA_CALLBACK_URL=https://<your-id>.ngrok-free.app/api/payments/mpesa/callback
MPESA_CONSUMER_KEY=your_consumer_key_here
MPESA_CONSUMER_SECRET=your_consumer_secret_here
# Sandbox shortcode + passkey (Daraja test defaults — swap for your real values in production)
MPESA_SHORTCODE=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
MPESA_CALLBACK_URL=https://your-ngrok-id.ngrok-free.app/api/payments/mpesa/callback
# sandbox | production
MPESA_ENV=sandbox

# Africa's Talking SMS Sandbox
AT_API_KEY=your_at_api_key
AT_USERNAME=sandbox
AT_SENDER_ID=RENTMO
